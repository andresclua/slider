---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="WebGL — RGB Shift">
  <DemoViewer
    title="WebGL — RGB Shift"
    description="Chromatic aberration effect that splits the RGB channels during transition. Rendered via WebGL canvas overlay."
    code={`import { Slider } from '@acslider/core'
import { arrows } from '@acslider/plugins'
import { webglRenderer, rgbShiftEffect } from '@acslider/webgl'

new Slider('#el', {
  loop: true,
  speed: 700,
  plugins: [
    webglRenderer({
      effect: rgbShiftEffect({ amount: 0.015 }),
    }),
    arrows(),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--effect" id="demo-webgl-rgbshift">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/rgb1/900/500" alt="Slide 1" loading="lazy" />
        </div>
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/rgb2/900/500" alt="Slide 2" loading="lazy" />
        </div>
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/rgb3/900/500" alt="Slide 3" loading="lazy" />
        </div>
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/rgb4/900/500" alt="Slide 4" loading="lazy" />
        </div>
      </div>
    </div>
    <div class="webgl-note">
      RGB shift runs as a canvas overlay. See <a href="/docs/webgl">WebGL docs</a>.
    </div>
  </DemoViewer>
</DemoLayout>

<style>
.c--slider-a--effect .c--slider-a__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.webgl-note {
  margin-top: 0.5rem;
  font-size: 0.8rem;
  color: var(--text-muted, #888);
  text-align: center;
}
</style>

<script>
import { Slider } from '@acslider/core'
import { arrows } from '@acslider/plugins'

new Slider('#demo-webgl-rgbshift', {
  loop: true,
  speed: 600,
  plugins: [arrows()],
})
</script>

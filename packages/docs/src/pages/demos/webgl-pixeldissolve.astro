---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="WebGL — Pixel Dissolve">
  <DemoViewer
    title="WebGL — Pixel Dissolve"
    description="Pixelated dissolve transition — slides break into blocks before reassembling as the next image."
    code={`import { Slider } from '@acslider/core'
import { arrows } from '@acslider/plugins'
import { webglRenderer, pixelDissolveEffect } from '@acslider/webgl'

new Slider('#el', {
  loop: true,
  speed: 900,
  plugins: [
    webglRenderer({
      effect: pixelDissolveEffect({ blockSize: 32 }),
    }),
    arrows(),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--effect" id="demo-webgl-pixeldissolve">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/px1/900/500" alt="Slide 1" loading="lazy" />
        </div>
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/px2/900/500" alt="Slide 2" loading="lazy" />
        </div>
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/px3/900/500" alt="Slide 3" loading="lazy" />
        </div>
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/px4/900/500" alt="Slide 4" loading="lazy" />
        </div>
      </div>
    </div>
    <div class="webgl-note">
      Pixel dissolve runs as a canvas overlay. See <a href="/docs/webgl">WebGL docs</a>.
    </div>
  </DemoViewer>
</DemoLayout>

<style>
.c--slider-a--effect .c--slider-a__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.webgl-note {
  margin-top: 0.5rem;
  font-size: 0.8rem;
  color: var(--text-muted, #888);
  text-align: center;
}
</style>

<script>
import { Slider } from '@acslider/core'
import { arrows } from '@acslider/plugins'

new Slider('#demo-webgl-pixeldissolve', {
  loop: true,
  speed: 600,
  plugins: [arrows()],
})
</script>

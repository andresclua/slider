---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'
---
<DemoLayout title="WebGL — Parallax Hover">
  <DemoViewer
    title="WebGL — Parallax Hover"
    description="Mouse-driven depth parallax. Move your cursor over the slide to see foreground and background layers shift independently."
    code={`import { Slider } from '@acslider/core'
import { webglRenderer, parallaxDepthEffect } from '@acslider/webgl'

new Slider('#el', {
  loop: true,
  plugins: [
    webglRenderer({
      mode: 'permanent',
      effect: parallaxDepthEffect({
        layers: 3,
        intensity: 0.04,
      }),
    }),
  ],
})`}
  >
    <div class="c--slider-a c--slider-a--effect" id="demo-webgl-parallax">
      <div class="c--slider-a__wrapper">
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/par1/900/500" alt="Slide 1" loading="lazy" />
        </div>
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/par2/900/500" alt="Slide 2" loading="lazy" />
        </div>
        <div class="c--slider-a__slide" data-slide>
          <img src="https://picsum.photos/seed/par3/900/500" alt="Slide 3" loading="lazy" />
        </div>
      </div>
    </div>
    <div class="webgl-note">
      Parallax hover runs as a permanent canvas overlay. See <a href="/docs/webgl">WebGL docs</a>.
    </div>
  </DemoViewer>
</DemoLayout>

<style>
.c--slider-a--effect .c--slider-a__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.webgl-note {
  margin-top: 0.5rem;
  font-size: 0.8rem;
  color: var(--text-muted, #888);
  text-align: center;
}
</style>

<script>
import { Slider } from '@acslider/core'
import { arrows } from '@acslider/plugins'

new Slider('#demo-webgl-parallax', {
  loop: true,
  speed: 600,
  plugins: [arrows()],
})
</script>

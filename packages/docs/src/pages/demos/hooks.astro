---
import DemoLayout from '../../layouts/DemoLayout.astro'
import DemoViewer from '../../components/DemoViewer.astro'

import basicCode     from './_scripts/hooks-basic.js?raw'
import gsapCode      from './_scripts/hooks-gsap.js?raw'
import adaptiveCode  from './_scripts/hooks-adaptive.js?raw'
import directionCode from './_scripts/hooks-direction.js?raw'
import cardsCode     from './_scripts/hooks-cards.js?raw'
import focusCode     from './_scripts/hooks-focus.js?raw'
---
<DemoLayout title="Hooks">
  <DemoViewer
    title="Hooks — beforeChange / afterChange"
    description="hooks() exposes lifecycle callbacks. Here beforeChange fades the outgoing slide out and afterChange logs the active slide."
    html={`<div id="demo-hooks-basic">
  <div class="demo-slide s-purple">1</div>
  <div class="demo-slide s-blue">2</div>
  <div class="demo-slide s-green">3</div>
  <div class="demo-slide s-amber">4</div>
  <div class="demo-slide s-red">5</div>
</div>
<p id="demo-hooks-log" style="margin-top:1rem;font-size:.85rem;color:#6b7280"></p>`}
    css={`.demo-slide { height:260px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; font-weight:700; color:#fff; transition: opacity .3s; }`}
    js={basicCode}
  >
    <div id="demo-hooks-basic">
      <div class="demo-slide s-purple">1</div>
      <div class="demo-slide s-blue">2</div>
      <div class="demo-slide s-green">3</div>
      <div class="demo-slide s-amber">4</div>
      <div class="demo-slide s-red">5</div>
    </div>
    <p id="demo-hooks-log" style="margin-top:1rem;font-size:.85rem;color:#6b7280"></p>
  </DemoViewer>

  <DemoViewer
    title="Hooks — GSAP content stagger"

---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}
const { title = 'SliderKit', description = 'A modern, accessible slider library' } = Astro.props
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — SliderKit</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />
</body>
<script>
import Boostify from 'boostify'
const bstf = new Boostify()
bstf.onload({
  worker: true,
  callback: () => {
    const s = document.createElement('script')
    s.async = true
    s.src = 'https://www.googletagmanager.com/gtag/js?id=G-SLYSZRXSQ2'
    s.onload = () => {
      window.dataLayer = window.dataLayer || []
      function gtag(...args: unknown[]) { window.dataLayer.push(args) }
      gtag('js', new Date())
      gtag('config', 'G-SLYSZRXSQ2')
    }
    document.head.appendChild(s)
  },
})
</script>
</html>
